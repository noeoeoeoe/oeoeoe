# Copy this file to `.env` and fill in values from your Supabase project:
#   Supabase Dashboard → Project Settings → API
# EXPO_PUBLIC_ vars are embedded in the client bundle (the anon key is safe to
# ship — Row Level Security is what protects the data, not key secrecy).
# Restart `npx expo start` after changing these.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
